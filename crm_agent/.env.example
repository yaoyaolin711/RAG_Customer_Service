# CRM Agent — DeepSeek
# 方式一：环境变量
DEEPSEEK_KEY=your_deepseek_api_key_here
# 方式二：密钥文件（默认读取仓库根目录 DEEPSEEK_KEY.txt，仅写一行密钥即可）
# DEEPSEEK_KEY_FILE=C:\path\to\your\DEEPSEEK_KEY.txt

LLM_MODEL_NAME=deepseek-chat
LLM_MODEL_BASE_URL=https://api.deepseek.com/v1

# 向量库与 Embedding（默认使用本机路径，可按需修改）
MILVUS_PATH=D:\Milvus
MILVUS_URI=D:\Milvus\milvus.db
BGE_M3_PATH=D:\BGE-M3
BGE_M3_DEVICE=cpu

# 本地 Reranker（GPU FP16，目标显存约 4GB）
RERANK_ENABLED=true
RERANKER_PATH=D:\BGE-Reranker-v2-m3
RERANKER_DEVICE=cuda
RERANKER_USE_FP16=true
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512
RAG_CANDIDATE_K=20
RERANK_RELEVANCE_THRESHOLD=0.2
ANSWER_CONFIDENCE_THRESHOLD=0.75

# 查询策略选择器（默认直接检索；LLM 与项目共用 DEEPSEEK_KEY）
QUERY_STRATEGY_ENABLED=true
QUERY_STRATEGY_DEFAULT=direct

# Redis / MySQL 会话：与 RAG_mode 共用仓库根目录配置
# 复制 ../../.env.session.example → ../../.env.session 后统一修改
# 不要在本文件再写 REDIS_* / MYSQL_*，否则会和共用配置打架
# RAG_SESSION_ENV_FILE=C:\path\to\.env.session

# 可选
EXPORT_DB_PATH=
CRM_AGENT_CONFIG_DIR=
API_PORT=7120
