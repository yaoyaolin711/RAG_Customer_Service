# 仓库共用：Redis / MySQL 会话配置（RAG_mode 与 crm_agent 共用）
# 复制本文件为仓库根目录 `.env.session` 后按需修改。
# 也可通过环境变量 RAG_SESSION_ENV_FILE 指定其它路径。

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=123
REDIS_DB=0
SESSION_TTL_SECONDS=86400

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123
MYSQL_DATABASE=rag_app
# 商品话术 FAQ 独立库（与会话库分离）
MYSQL_FAQ_DATABASE=rag_faq
